{
  "name": "Calmi — Routines Histoires Auto",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 5
            }
          ]
        }
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000001",
      "name": "Toutes les 5 minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [100, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://ioeihnoxvtpxtqhxklpw.supabase.co/functions/v1/due-story-routines",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-webhook-secret",
              "value": "={{ $env.N8N_WEBHOOK_SECRET }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={}",
        "options": {
          "timeout": 30000,
          "response": {
            "response": {
              "neverError": false
            }
          }
        }
      },
      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "Réclamer les routines dues",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [320, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-jobs-gt-0",
              "leftValue": "={{ $json.processed }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "Des jobs à traiter ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [540, 300]
    },
    {
      "parameters": {
        "fieldToSplitOut": "jobs",
        "options": {
          "disableDotNotation": false,
          "destinationFieldName": "",
          "include": "noOtherFields"
        }
      },
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "Éclater les jobs",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [760, 200]
    },
    {
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "cond-fast",
                    "leftValue": "={{ $json.mode }}",
                    "rightValue": "fast",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "fast"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "cond-guided",
                    "leftValue": "={{ $json.mode }}",
                    "rightValue": "guided",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "guided"
            }
          ]
        },
        "fallbackOutput": "none",
        "options": {}
      },
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "name": "Mode fast ou guided ?",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [980, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.assembleUrl }}",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-webhook-secret",
              "value": "={{ $env.N8N_WEBHOOK_SECRET }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ mode: 'fast', fastStoryPromptKey: $json.fastStoryPromptKey, durationMinutes: $json.durationMinutes, generateVideo: $json.generateVideo, userId: $json.userId }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "a1b2c3d4-0006-0006-0006-000000000006",
      "name": "Assembler payload (fast)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1200, 100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Mode fast ou guided ?').item.json.storyWebhookUrl }}",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Calmi-Webhook-Secret",
              "value": "={{ $env.N8N_WEBHOOK_SECRET }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify($json.payload) }}",
        "options": {
          "timeout": 300000
        }
      },
      "id": "a1b2c3d4-0007-0007-0007-000000000007",
      "name": "Déclencher histoire (fast)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1420, 100]
    },
    {
      "parameters": {
        "method": "POST",
