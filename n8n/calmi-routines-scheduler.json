              "value": "={{ $('Mode fast ou guided ?').item.json.childrenIds }}",
              "type": "array"
            },
            {
              "id": "assign-duration",
              "name": "durationMinutes",
              "value": "={{ $('Mode fast ou guided ?').item.json.durationMinutes }}",
              "type": "number"
            },
            {
              "id": "assign-video",
              "name": "generateVideo",
              "value": "={{ $('Mode fast ou guided ?').item.json.generateVideo }}",
              "type": "boolean"
            },
            {
              "id": "assign-assembleUrl",
              "name": "assembleUrl",
              "value": "={{ $('Mode fast ou guided ?').item.json.assembleUrl }}",
              "type": "string"
            },
            {
              "id": "assign-storyUrl",
              "name": "storyWebhookUrl",
              "value": "={{ $('Mode fast ou guided ?').item.json.storyWebhookUrl }}",
              "type": "string"
            }
          ]
        },
        "include": "none",
        "options": {}
      },
      "id": "a1b2c3d4-0009-0009-0009-000000000009",
      "name": "Préparer params (guided)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1420, 320]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.assembleUrl }}",
