        "body": "={{ JSON.stringify($json.titlePayload) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "a1b2c3d4-0008-0008-0008-000000000008",
      "name": "Générer les titres",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1200, 320]
    },
    {
      "parameters": {
        "mode": "manual",
        "duplicateItem": false,
        "assignments": {
          "assignments": [
            {
              "id": "assign-title",
              "name": "selectedTitle",
              "value": "={{ $json.title_1 ?? $json.titles?.[0] ?? '' }}",
              "type": "string"
            },
            {
              "id": "assign-routineId",
              "name": "routineId",
              "value": "={{ $('Mode fast ou guided ?').item.json.routineId }}",
